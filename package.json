{
  "name": "@fagom174/agentkit",
  "version": "0.1.2",
  "description": "CLI package manager for Claude AI agent skills",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agk": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "docs:dev": "docusaurus start",
    "docs:build": "docusaurus build",
    "docs:serve": "docusaurus serve",
    "docs:clear": "docusaurus clear"
  },
  "files": ["dist"],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^13.4.0",
    "node-fetch": "^3.3.0",
    "ora": "^8.1.0",
    "semver": "^7.8.0",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@docusaurus/core": "^2.4.0",
    "@docusaurus/preset-classic": "^2.4.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.12.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "clsx": "^2.0.0",
    "eslint": "^8.50.0",
    "prism-react-renderer": "^2.1.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["cli", "agent", "claude", "skills", "ai", "package-manager"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fagom/agentkit.git"
  }
}
